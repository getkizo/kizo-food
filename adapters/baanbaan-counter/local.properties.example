# Copy this file to local.properties and set the path to your Android SDK.
# local.properties is gitignored — never commit it.

sdk.dir=/path/to/your/Android/Sdk
# macOS example: sdk.dir=/Users/yourname/Library/Android/sdk
# Linux example: sdk.dir=/home/yourname/Android/Sdk
# Windows example: sdk.dir=C\:\\Users\\yourname\\AppData\\Local\\Android\\Sdk

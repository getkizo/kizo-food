# ─────────────────────────────────────────────────────────────────────────────
# Merchant Appliance — Environment Variables
# Copy this file to .env and fill in the values before starting the server.
# Required variables will cause an immediate startup failure if not set.
# Optional variables are disabled or use safe defaults when absent.
# ─────────────────────────────────────────────────────────────────────────────

# ── Security (Required) ───────────────────────────────────────────────────────

# JWT signing key — must be at least 32 characters. Generate with:
#   openssl rand -base64 48
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-chars

# Master encryption key passphrase for AES-256-GCM envelope encryption of stored API keys.
# Strongly recommended in production. Generate with:
#   openssl rand -base64 48
MASTER_KEY_PASSPHRASE=replace-with-a-strong-passphrase

# Ed25519 public key for code-signing verification (hex-encoded, 64 chars).
# Injected automatically by `bun run sign`. Leave blank during development —
# the server skips verification when no manifest.json is present.
# CODE_SIGNING_PUBLIC_KEY=

# ── Server ────────────────────────────────────────────────────────────────────

# HTTP listen port (default: 3000)
# PORT=3000

# HTTP bind address (default: 127.0.0.1 — loopback only, Cloudflare Tunnel connects locally)
# SERVER_BIND=127.0.0.1

# Runtime environment — set to "production" on the appliance
NODE_ENV=development

# Log level: debug | info | warn | error (default: info)
# LOG_LEVEL=info

# ── Database ──────────────────────────────────────────────────────────────────

# SQLite database file path (default: ./data/merchant.db)
# DATABASE_PATH=./data/merchant.db

# ── CORS ──────────────────────────────────────────────────────────────────────

# Allowed CORS origins (comma-separated). In production, set to the Cloudflare Tunnel URL.
# Default is localhost:3000,localhost:5173 (dev only — logged as a warning).
# CORS_ORIGIN=https://your-tunnel.baanbaan.org

# ── Network / IP Allowlist ────────────────────────────────────────────────────

# Comma-separated IP addresses or CIDR ranges allowed to access merchant routes.
# When absent, merchant routes are open to all IPs (suitable for dev; restrict in production).
# ALLOWED_MERCHANT_IPS=192.168.1.0/24,10.0.0.1

# Restrict merchant routes to LAN (RFC-1918) addresses in addition to ALLOWED_MERCHANT_IPS.
# RESTRICT_MERCHANT_TO_LOCAL=true

# ── Web Push Notifications ────────────────────────────────────────────────────

# VAPID keys for Web Push. Generate with:
#   bun run generate:vapid
# Push notifications are disabled when these are absent.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@your-domain.com

# ── Clover POS Integration ────────────────────────────────────────────────────

# Clover merchant API token (from Clover Developer Dashboard -> App Settings)
# Clover integration is disabled when absent.
# CLOVER_API_TOKEN=

# Clover merchant ID (from Clover Developer Dashboard)
# CLOVER_MERCHANT_ID=

# Use Clover sandbox endpoint (set to "true" during development)
# CLOVER_SANDBOX=true

# Clover Flex device ID — associates injected orders with this device so they
# appear in the device's order list without staff needing to search manually.
# Find it in Clover Dashboard → Devices → your Flex → Device ID (e.g. DV1AB2CD3EF).
# When absent, orders appear in the web portal only (not on the device).
# CLOVER_DEVICE_ID=

# Clover webhook HMAC signing secret (from Clover Developer Dashboard -> Webhooks).
# When set, all incoming Clover webhook requests are verified against this secret.
# When absent, Clover webhooks are accepted without signature verification.
# CLOVER_WEBHOOK_SECRET=

# ── Payment Processors ────────────────────────────────────────────────────────

# Override Finix API base URL (used by the PAX A920 emulator for local testing)
# FINIX_EMULATOR_URL=http://localhost:9333

# ── OAuth Providers ───────────────────────────────────────────────────────────

# Google OAuth -- create credentials at console.cloud.google.com
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://your-tunnel.baanbaan.org/api/auth/oauth/google/callback

# Apple Sign In -- requires Apple Developer account
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=
# APPLE_REDIRECT_URI=https://your-tunnel.baanbaan.org/api/auth/oauth/apple/callback

# Facebook Login -- create app at developers.facebook.com
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# FACEBOOK_REDIRECT_URI=https://your-tunnel.baanbaan.org/api/auth/oauth/facebook/callback

# Bypass OAuth for local development (set to "true" -- never use in production)
# MOCK_OAUTH=true

# ── WebAuthn / Passkeys ───────────────────────────────────────────────────────

# WebAuthn RP ID -- must be the bare hostname of the appliance.
# When set, incoming Host/Origin headers are ignored for RP validation (production-safe).
# When absent, RP ID is derived from the request Host header (acceptable for localhost dev).
# WEBAUTHN_EXPECTED_DOMAIN=hanuman-thai-cafe-kirkland.baanbaan.org

# ── Printer ───────────────────────────────────────────────────────────────────

# Default printer IP override (optional -- merchant profile stores the primary printer IP)
# PRINTER_IP=192.168.1.100

# Path to Chrome/Chromium executable for Puppeteer HTML receipt rendering.
# Only required when receipt_style = 'html' is enabled for the merchant.
# On Raspberry Pi OS: /usr/bin/chromium-browser
# CHROME_EXECUTABLE_PATH=/usr/bin/chromium-browser

# Dump receiptline markup to stdout for debugging printer output (set to "true")
# DEBUG_PRINT_MARKUP=true

# ── Background Services ───────────────────────────────────────────────────────

# Finix reconciliation sweep interval in milliseconds (default: 30000 = 30 seconds)
# RECONCILE_DELAY_MS=30000

# ── Development ───────────────────────────────────────────────────────────────

# Stable hardware UUID override for development. Used instead of /proc/cpuinfo in
# non-production mode. Set to any stable string (e.g. "dev-local").
# Falls back to "dev-hardware-uuid-localhost" when absent (non-production only).
# DEV_HARDWARE_UUID=dev-local

# Copy to /etc/ocr-api.env, fill in real values, chmod 600 root:root.
# Used by deploy/ocr-api.service via EnvironmentFile=.

# Static secret the calling backend sends in the X-API-Key header.
# Generate with: openssl rand -base64 32
OCR_API_KEY=replace-me

# Mistral API key (https://console.mistral.ai/).
MISTRAL_API_KEY=replace-me

# Optional overrides (uncomment to change):
# OCR_DATA_DIR=/home/pi/invoice-ocr
# OCR_MAX_PAGES=10
# OCR_MAX_UPLOAD_MB=50

{
  "name": "@kizo/campaigns-redirector",
  "version": "1.0.0",
  "description": "QR-coupon redirector, scan logger, and campaign management platform. First-party infrastructure for kizo.example — reusable as open-source Kizō module.",
  "type": "module",
  "scripts": {
    "dev": "bun --env-file ../../.env run --watch src/server.ts",
    "start": "bun --env-file ../../.env run src/server.ts",
    "test": "bun test test/ --timeout 30000",
    "db:migrate": "bun run src/db/migrate.ts",
    "seed-admin": "bun run src/scripts/seed-admin.ts"
  },
  "dependencies": {
    "hono": "^4.12.8",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/qrcode": "^1.5.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "author": "JJ Dubray, Cognitive Fab LLC",
  "license": "MIT"
}

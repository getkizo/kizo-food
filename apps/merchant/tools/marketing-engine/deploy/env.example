# /etc/marketing-engine.env
#
# IMPORTANT: this file is loaded AFTER the main Kizo .env
# (/home/kizo/kizo-food/v2/.env), so every variable here
# overrides the shared file.  PORT and SESSION_SECRET MUST be set here
# — they are not in the shared .env.
#
# Copy to /etc/marketing-engine.env and fill in production values.
# Generate secrets with: openssl rand -hex 32

# Port — must override the PORT=3000 that the shared .env sets for the POS
PORT=3100

# Database path (directory must exist and be writable by the kizo user)
DB_PATH=/var/lib/kizo/campaigns.db

# Where to redirect QR scans when no campaign matches (i.e. your store URL)
DEFAULT_REDIRECT=https://demo-restaurant.kizo.example

# Session secret for the /marketing/* admin UI cookie (generate once, never rotate)
SESSION_SECRET=<output of: openssl rand -hex 32>

# Shared token for internal calls between marketing-engine and the POS.
# Must match CAMPAIGN_SYNC_TOKEN in the main Kizo .env.
KIZO_SYNC_TOKEN=<same value as CAMPAIGN_SYNC_TOKEN in v2/.env>
KIZO_SYNC_URL=http://127.0.0.1:3000/internal/campaigns/sync
KIZO_ALERT_TOKEN=<same value as CAMPAIGN_SYNC_TOKEN in v2/.env>
KIZO_ALERT_URL=http://127.0.0.1:3000/internal/campaigns/alert

NODE_ENV=production

# Optional: IP allowlist for /marketing/* dashboard.
# Inherits ALLOWED_MERCHANT_IPS and RESTRICT_MERCHANT_TO_LOCAL from the shared
# .env automatically — only set these here if you need different values.
# RESTRICT_MERCHANT_TO_LOCAL=true
# ALLOWED_MERCHANT_IPS=203.0.113.42,2600:382:30e1:405::/64

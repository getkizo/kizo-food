{
  "name": "@kizo/register",
  "version": "1.0.0",
  "description": "ARM cluster appliance bridging customers and merchant POS systems",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "start": "bun run src/server.ts",
    "test": "bun test test/ --timeout 30000",
    "test:coverage": "bun test test/ --timeout 30000 --coverage",
    "test:watch": "bun test test/ --watch --timeout 30000",
    "build": "bun build src/server.ts --outdir=dist --target=bun",
    "sign": "bun run build/sign-release.ts",
    "verify": "bun run src/crypto/verify-code.ts",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:seed": "bun run src/db/seed.ts",
    "generate:vapid": "bun run scripts/generate-vapid.ts",
    "generate:icons": "bun run scripts/generate-icons.ts",
    "emulator": "bun run src/tools/printer-emulator.ts",
    "emulator:a920": "bun run src/tools/a920-emulator.ts",
    "test:e2e": "bunx playwright test",
    "test:e2e:headed": "bunx playwright test --headed",
    "test:e2e:debug": "bunx playwright test --debug",
    "test:e2e:install": "bunx playwright install chromium"
  },
  "dependencies": {
    "@noble/ed25519": "^2.3.0",
    "hono": "^4.12.8",
    "nodemailer": "^8.0.3",
    "puppeteer-core": "^22.15.0",
    "qrcode": "^1.5.4",
    "receiptline": "4.0.0",
    "sam-fsm": "0.9.24",
    "sam-pattern": "^1.5.10",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bun": "^1.3.11",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "bun-types": "^1.3.11",
    "typescript": "^5.9.3",
    "typescript-language-server": "^5.1.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "keywords": [
    "appliance",
    "arm",
    "raspberry-pi",
    "pos",
    "restaurant",
    "sam-pattern"
  ],
  "author": {
    "name": "Jean-Jacques Dubray",
    "email": "cto@cognitivefab.com",
    "url": "https://cognitivefab.com"
  },
  "license": "MIT"
}
